---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import { PAGE_HOME_LINK_LABELS, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import meImage from '../assets/me4.png';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} image={meImage} />
	</head>
	<body>

	<div style="text-align: center; margin-bottom: 2rem;">
		<Image src={meImage} alt="Me" width={300} height={300} style="border-radius: 12px;" />
	</div>
		<main>
			<h3 style="text-align: center;">My Home Is My Castle</h3>
			<div>
				<a href={`${import.meta.env.BASE_URL}about`}>Intro</a>
			</div>
			<div>
				<a href={`${import.meta.env.BASE_URL}tea`}>Let's drink some tea</a>
			</div>
			<div>
				<a href={`${import.meta.env.BASE_URL}teapots-for-sale`}>Wanna buy a Yixing teapot?</a>
			</div>
			<div>
				<a href={`${import.meta.env.BASE_URL}god-is-dead`}>{PAGE_HOME_LINK_LABELS.godIsDead}</a>
			</div>

		</main>
		<Footer />
	</body>
</html>
