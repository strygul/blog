---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { PAGE_DESCRIPTIONS, PAGE_INDEX_SUBTITLES, PAGE_INDEX_TITLES, SITE_TITLE } from '../../consts';
import heroImage from '../../assets/god-is-dead/hero.png';

const base = import.meta.env.BASE_URL;
const posts = (await getCollection('god-is-dead')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const godIsDeadHeading =
	PAGE_INDEX_TITLES.godIsDead.split(': ')[0] ?? PAGE_INDEX_TITLES.godIsDead;
const godIsDeadSubheading = PAGE_INDEX_SUBTITLES.godIsDead;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${PAGE_INDEX_TITLES.godIsDead} — ${SITE_TITLE}`}
			description={PAGE_DESCRIPTIONS.godIsDeadIndex}
			image={heroImage}
		/>
		<style>
			main {
				width: 960px;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li img.post-list-hero--capped {
				display: block;
				margin-inline: auto;
				max-width: 100%;
				width: auto;
				height: auto;
				object-fit: contain;
			}
			ul li:first-child img.post-list-hero--capped {
				width: auto;
				max-width: min(100%, 720px);
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover h4,
			ul li a:hover h5,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div style="text-align: center; margin-bottom: 2rem;">
				<h1>{godIsDeadHeading}</h1>
				{
					godIsDeadSubheading && (
						<p style="margin-top: 0; font-size: 1.125rem; color: rgb(var(--gray-dark));">
							{godIsDeadSubheading}
						</p>
					)
				}
				<Image
					src={heroImage}
					alt="Illustration of a haloed figure with circuit traces on the face, glowing eyes, and light rays—sacred iconography blended with technology"
					width={1024}
					height={682}
					style="border-radius: 12px; max-width: 100%; height: auto;"
				/>
				<p style="text-align: left; text-indent: 1.5em;">
					This is a separate corner of the site for longer essays on building software, living with AI tools, and
					the habits of thought that come with both—written when I want more room than a single post on the main
					blog allows.
				</p>
			</div>
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`${base}god-is-dead/${post.id}/`}>
									{post.data.heroImage && (
										<Image
											width={720}
											height={360}
											src={post.data.heroImage}
											alt=""
											class:list={[post.data.heroImageMaxHeight != null && 'post-list-hero--capped']}
											style={
												post.data.heroImageMaxHeight != null
													? {
															maxHeight: `${post.data.heroImageMaxHeight}px`,
															maxWidth: '100%',
															width: 'auto',
															height: 'auto',
															objectFit: 'contain',
														}
													: undefined
											}
										/>
									)}
									<h5 class="title">{post.data.title}</h5>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
