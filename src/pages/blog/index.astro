---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const base = import.meta.env.BASE_URL;

const allPosts = [
	...(await getCollection('blog')).map((p) => ({ post: p, basePath: `${base}blog` })),
	...(await getCollection('tea')).map((p) => ({ post: p, basePath: `${base}tea` })),
	...(await getCollection('teapots-for-sale')).map((p) => ({ post: p, basePath: `${base}tea/teapots-for-sale` })),
	...(await getCollection('god-is-dead')).map((p) => ({ post: p, basePath: `${base}god-is-dead` })),
	...(await getCollection('ballet')).map((p) => ({ post: p, basePath: `${base}ballet` })),
].sort(
	(a, b) =>
		b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf() ||
		a.post.id.localeCompare(b.post.id),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`All Posts — ${SITE_TITLE}`}
			description="Every post from this blog: tea, teapots, software, ballet, and more."
		/>
		<style>
			main {
				width: 960px;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li img.post-list-hero--capped {
				display: block;
				margin-inline: auto;
				max-width: 100%;
				width: auto;
				height: auto;
				object-fit: contain;
			}
			ul li:first-child img.post-list-hero--capped {
				width: auto;
				max-width: min(100%, 720px);
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<ul>
					{
						allPosts.map(({ post, basePath }) => (
							<li>
								<a href={`${basePath}/${post.id}/`}>
									{post.data.heroImage && (
										<Image
											width={720}
											height={360}
											src={post.data.heroImage}
											alt=""
											class:list={[post.data.heroImageMaxHeight != null && 'post-list-hero--capped']}
											style={
												post.data.heroImageMaxHeight != null
													? {
															maxHeight: `${post.data.heroImageMaxHeight}px`,
															maxWidth: '100%',
															width: 'auto',
															height: 'auto',
															objectFit: 'contain',
														}
													: undefined
											}
										/>
									)}
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
