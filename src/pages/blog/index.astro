---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const base = import.meta.env.BASE_URL;

const categories = [
	{ label: 'Tea', posts: await getCollection('tea'), basePath: `${base}tea` },
	{ label: 'Teapots for Sale', posts: await getCollection('teapots-for-sale'), basePath: `${base}tea/teapots-for-sale` },
	{ label: 'God Is Dead', posts: await getCollection('god-is-dead'), basePath: `${base}god-is-dead` },
	{ label: 'Ballet', posts: await getCollection('ballet'), basePath: `${base}ballet` },
	{ label: 'Blog', posts: await getCollection('blog'), basePath: `${base}blog` },
].map(({ label, posts, basePath }) => ({
	label,
	basePath,
	posts: posts.sort(
		(a, b) =>
			b.data.pubDate.valueOf() - a.data.pubDate.valueOf() ||
			a.id.localeCompare(b.id),
	),
})).filter(({ posts }) => posts.length > 0);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`All Posts — ${SITE_TITLE}`}
			description="Every post from this blog: tea, teapots, software, ballet, and more."
		/>
		<style>
			section {
				margin-bottom: 3rem;
			}

			.section-header {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				margin: 0;
			}

			.category-link {
				font-size: inherit;
				font-weight: bold;
				text-decoration: none;
				color: inherit;
			}

			.category-link:hover {
				color: rgb(var(--accent));
			}

			.expand-btn {
				cursor: pointer;
				background: none;
				border: none;
				padding: 0;
				font: inherit;
				color: inherit;
				line-height: 1;
				display: flex;
				align-items: center;
			}

			.expand-btn:hover .section-icon {
				color: rgb(var(--accent));
			}

			.section-icon {
				display: inline-block;
				transition: transform 0.3s ease-out;
				font-size: 1.1em;
				line-height: 1;
			}

			.section-icon.expanded {
				transform: rotate(90deg);
			}

			.section-content {
				display: grid;
				grid-template-rows: 0fr;
				opacity: 0;
				transition: grid-template-rows 0.3s ease-out, opacity 0.3s ease-out;
			}

			.section-content.unfolded {
				grid-template-rows: 1fr;
				opacity: 1;
			}

			.section-inner {
				min-height: 0;
				overflow: hidden;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			{
				categories.map(({ label, posts, basePath }, index) => (
					<section>
						<h3 class="section-header">
							<a href={basePath} class="category-link">{label}</a>
							<button class="expand-btn" data-index={index} aria-expanded="false" aria-controls={`section-${index}`}>
								<span class="section-icon">›</span>
							</button>
						</h3>
						<div class="section-content folded" id={`section-${index}`}>
							<div class="section-inner">
								{posts.map((post) => (
									<div>
										<a href={`${basePath}/${post.id}/`}>{post.data.title}</a>
									</div>
								))}
							</div>
						</div>
					</section>
				))
			}
		</main>
		<Footer />

		<script>
			const buttons = document.querySelectorAll('.expand-btn');

			buttons.forEach((btn) => {
				btn.addEventListener('click', () => toggleSection(btn));
			});

			function toggleSection(btn) {
				const index = btn.getAttribute('data-index');
				const content = document.getElementById(`section-${index}`);
				const icon = btn.querySelector('.section-icon');

				const isCollapsed = content.classList.contains('folded');
				content.classList.toggle('folded', !isCollapsed);
				content.classList.toggle('unfolded', isCollapsed);
				icon.classList.toggle('expanded', isCollapsed);
				btn.setAttribute('aria-expanded', String(isCollapsed));
			}
		</script>
	</body>
</html>
