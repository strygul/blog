---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const base = import.meta.env.BASE_URL;

const categories = [
	{ label: 'Tea', posts: await getCollection('tea'), basePath: `${base}tea` },
	{ label: 'Teapots for Sale', posts: await getCollection('teapots-for-sale'), basePath: `${base}tea/teapots-for-sale` },
	{ label: 'God Is Dead', posts: await getCollection('god-is-dead'), basePath: `${base}god-is-dead` },
	{ label: 'Ballet', posts: await getCollection('ballet'), basePath: `${base}ballet` },
	{ label: 'Blog', posts: await getCollection('blog'), basePath: `${base}blog` },
].map(({ label, posts, basePath }) => ({
	label,
	basePath,
	posts: posts.sort(
		(a, b) =>
			b.data.pubDate.valueOf() - a.data.pubDate.valueOf() ||
			a.id.localeCompare(b.id),
	),
})).filter(({ posts }) => posts.length > 0);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`All Posts — ${SITE_TITLE}`}
			description="Every post from this blog: tea, teapots, software, ballet, and more."
		/>
		<style>
			section {
				margin-bottom: 3rem;
			}

			.section-header {
				cursor: pointer;
				background: none;
				border: none;
				padding: 0;
				font: inherit;
				color: inherit;
				width: 100%;
				text-align: left;
			}

			.section-header h3 {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				margin: 0;
			}

			.section-header:hover h3 {
				color: rgb(var(--accent));
			}

			.section-icon {
				display: inline-block;
				transition: transform 0.3s ease-out;
				font-size: 1em;
				line-height: 1;
				min-width: 1em;
			}

			.section-icon.expanded {
				transform: rotate(90deg);
			}

			.section-content {
				display: grid;
				grid-template-rows: 0fr;
				opacity: 0;
				transition: grid-template-rows 0.3s ease-out, opacity 0.3s ease-out;
			}

			.section-content.unfolded {
				grid-template-rows: 1fr;
				opacity: 1;
			}

			.section-inner {
				min-height: 0;
				overflow: hidden;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			{
				categories.map(({ label, posts, basePath }, index) => (
					<section>
						<button class="section-header" data-index={index} aria-expanded="false">
							<h3>
								<span class="section-icon">></span>
								{label}
							</h3>
						</button>
						<div class="section-content folded" id={`section-${index}`}>
							<div class="section-inner">
								{posts.map((post) => (
									<div>
										<a href={`${basePath}/${post.id}/`}>{post.data.title}</a>
									</div>
								))}
							</div>
						</div>
					</section>
				))
			}
		</main>
		<Footer />

		<script>
			const headers = document.querySelectorAll('.section-header');

			headers.forEach((header) => {
				header.addEventListener('click', () => toggleSection(header));
			});

			function toggleSection(header) {
				const index = header.getAttribute('data-index');
				const content = document.getElementById(`section-${index}`);
				const icon = header.querySelector('.section-icon');

				const isCollapsed = content.classList.contains('folded');
				content.classList.toggle('folded', !isCollapsed);
				content.classList.toggle('unfolded', isCollapsed);
				icon.classList.toggle('expanded', isCollapsed);
				header.setAttribute('aria-expanded', String(isCollapsed));
			}
		</script>
	</body>
</html>
