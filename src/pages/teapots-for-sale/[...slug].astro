---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('teapots-for-sale');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'teapots-for-sale'>;

const post = Astro.props;
const { Content } = await render(post);
const socialImageSrc = `/teapots-for-sale/${post.id}/${post.id}_intro.png`;
---

<BlogPost {...post.data} socialImageSrc={socialImageSrc}>
	<Content />
</BlogPost>
