---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const blogPosts = await getCollection('blog');
	const teaPosts = await getCollection('tea');
	const teapotsForSalePosts = await getCollection('teapots-for-sale');
	const allPosts = [...blogPosts, ...teaPosts, ...teapotsForSalePosts];

	// Extract all categories from all posts (handling arrays)
	const allCategories = allPosts.flatMap((post) => post.data.category);
	const categories = Array.from(new Set(allCategories));

	return categories.map((category) => {
		const categoryPosts = allPosts
			.filter((post) =>
				post.data.category.some((cat) => cat.toLowerCase() === category.toLowerCase()),
			)
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

		return {
			params: { slug: category.toLowerCase() },
			props: { category, posts: categoryPosts },
		};
	});
}

type Props = {
	category: string;
	posts: Array<
		| Awaited<ReturnType<typeof getCollection<'blog'>>>[number]
		| Awaited<ReturnType<typeof getCollection<'tea'>>>[number]
		| Awaited<ReturnType<typeof getCollection<'teapots-for-sale'>>>[number]
	>;
};

const { category, posts } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${category} - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			.category-header {
				margin-bottom: 2rem;
			}
			.category-header h1 {
				margin: 0 0 0.5rem 0;
			}
			.category-header p {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li img.post-list-hero--capped {
				display: block;
				margin-inline: auto;
				max-width: 100%;
				width: auto;
				height: auto;
				object-fit: contain;
			}
			ul li:first-child img.post-list-hero--capped {
				width: auto;
				max-width: min(100%, 720px);
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<div class="category-header">
					<h1>{category}</h1>
					<p>
						{posts.length} post{posts.length !== 1 ? 's' : ''} in this category
					</p>
				</div>
				<ul>
					{
						posts.map((post) => {
							const basePath =
								post.collection === 'tea'
									? `${base}tea`
									: post.collection === 'teapots-for-sale'
										? `${base}teapots-for-sale`
										: `${base}blog`;
							return (
								<li>
									<a href={`${basePath}/${post.id}/`}>
										{post.data.heroImage && (
											<Image
												width={720}
												height={360}
												src={post.data.heroImage}
												alt=""
												class:list={[post.data.heroImageMaxHeight != null && 'post-list-hero--capped']}
												style={
													post.data.heroImageMaxHeight != null
														? {
																maxHeight: `${post.data.heroImageMaxHeight}px`,
																maxWidth: '100%',
																width: 'auto',
																height: 'auto',
																objectFit: 'contain',
															}
														: undefined
												}
											/>
										)}
										<h4 class="title">{post.data.title}</h4>
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</a>
								</li>
							);
						})
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
