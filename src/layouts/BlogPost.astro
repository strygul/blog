---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_AUTHOR } from '../consts';
import '../styles/tea-post.css';

type CollectionData =
	| CollectionEntry<'blog'>['data']
	| CollectionEntry<'tea'>['data']
	| CollectionEntry<'teapots-for-sale'>['data']
	| CollectionEntry<'god-is-dead'>['data']
	| CollectionEntry<'ballet'>['data'];

type Props = CollectionData & {
	jsonLdType?: 'BlogPosting' | 'AboutPage';
	/** Root-relative path under `public/` for share previews (og:image, JSON-LD). */
	socialImageSrc?: string;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	heroImageMaxHeight,
	category,
	jsonLdType = 'BlogPosting',
	socialImageSrc,
} = Astro.props;
// category is now an array, check if it includes 'Tea'
const categories = Array.isArray(category) ? category : [category];

const site = Astro.site!;
const pageUrl = new URL(Astro.url.pathname, site).href;
const coverForMeta = heroImage ?? FallbackImage;
const shareImageAbsolute =
	socialImageSrc != null ? new URL(socialImageSrc, site).href : new URL(coverForMeta.src, site).href;
const authorUrl = new URL('/about', site).href;
const structuredData =
	jsonLdType === 'AboutPage'
		? {
				'@context': 'https://schema.org',
				'@type': 'AboutPage',
				name: title,
				description,
				url: pageUrl,
				mainEntity: {
					'@type': 'Person',
					name: SITE_AUTHOR,
					url: authorUrl,
				},
			}
		: {
				'@context': 'https://schema.org',
				'@type': 'BlogPosting',
				headline: title,
				description,
				image: [shareImageAbsolute],
				datePublished: pubDate.toISOString(),
				...(updatedDate
					? { dateModified: updatedDate.toISOString() }
					: { dateModified: pubDate.toISOString() }),
				mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
				author: {
					'@type': 'Person',
					name: SITE_AUTHOR,
					url: authorUrl,
				},
				publisher: {
					'@type': 'Person',
					name: SITE_AUTHOR,
				},
			};
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={coverForMeta}
			ogImageUrl={shareImageAbsolute}
			article={
				jsonLdType === 'AboutPage'
					? undefined
					: { publishedTime: pubDate, modifiedTime: updatedDate }
			}
		/>
		<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
		{categories.includes('Tea') && <link rel="stylesheet" href={`${import.meta.env.BASE_URL}css/f1-seals.css`} />}
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
			}
			.hero-image--max-height {
				max-width: min(720px, calc(100% - 2em));
				margin-inline: auto;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.prose ul,
			.prose ol {
				margin-top: 0.35em;
				margin-bottom: 0.75em;
				padding-left: 1.5em;
			}
			.prose p:has(+ ul),
			.prose p:has(+ ol) {
				margin-bottom: 0.5em;
			}
			.prose ul:has(+ p),
			.prose ol:has(+ p) {
				margin-bottom: 0.5em;
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class:list={['hero-image', { 'hero-image--max-height': heroImageMaxHeight != null }]}>
					{
						heroImage && (
							<Image
								width={1020}
								height={510}
								src={heroImage}
								alt={title}
								loading="eager"
								fetchpriority="high"
								style={
									heroImageMaxHeight != null
										? {
												maxHeight: `${heroImageMaxHeight}px`,
												maxWidth: '100%',
												width: 'auto',
												height: 'auto',
												objectFit: 'contain',
											}
										: undefined
								}
							/>
						)
					}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
